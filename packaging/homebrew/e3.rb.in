# typed: strict
# frozen_string_literal: true

# Formula for the e3 terminal multiplexer.
class E3 < Formula
  desc "I3-inspired terminal multiplexer"
  homepage "https://github.com/boyswan/e3"
  version "@VERSION@"
  license "MIT"

  depends_on :macos
  depends_on "sdl3"
  depends_on "sdl3_ttf"

  on_macos do
    on_arm do
      url "https://github.com/boyswan/e3/releases/download/v@VERSION@/e3-@VERSION@-Darwin-arm64.tar.gz"
      sha256 "@ARM64_SHA256@"
    end

    on_intel do
      url "https://github.com/boyswan/e3/releases/download/v@VERSION@/e3-@VERSION@-Darwin-x86_64.tar.gz"
      sha256 "@X86_64_SHA256@"
    end
  end

  def install
    bin.install "e3"
    pkgshare.install "config.example.yaml"
  end

  test do
    assert_match "e3 #{version}", shell_output("#{bin}/e3 --version")
  end
end
